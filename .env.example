# ─── ESF Automation Agent — Environment Variables ──────────────────────────────

# OPTIONAL — only required for AI-enhanced test generation (Claude API)
# Agent/Browser crawl mode works WITHOUT this key
ANTHROPIC_API_KEY=sk-ant-api03-...

# Server port (default: 3001)
PORT=3001

# Rate limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=30

# Node environment
NODE_ENV=development
